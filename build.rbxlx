	hp = 3,
	rarity = 1,
	growthTime = 20,
	seedDropChance = 0.6,
	gemDropMin = 0,
	gemDropMax = 1,
	isSplicable = true,
	unsplicable = false,
	tradeable = true,
	seedId = 103,       -- Cave Background Seed
	color = Color3.fromRGB(60, 60, 70),
})

