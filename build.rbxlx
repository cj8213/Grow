define(4, {
	name = "Lava",
	type = ItemTypes.LAVA,
	hp = 2,
	rarity = 3,
	growthTime = 90,
	seedDropChance = 0.3,
	gemDropMin = 2,
	gemDropMax = 5,
	isSplicable = true,
	unsplicable = false,
	tradeable = true,
	seedId = 104,       -- Lava Seed
	color = Color3.fromRGB(255, 69, 0),
})

-- 5: Bedrock — indestructible foundation block
define(5, {
