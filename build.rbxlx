          <Item class="ModuleScript" referent="34">
            <Properties>
              <string name="Name">HUD</string>
              <string name="Source"><![CDATA[-- HUD.lua (client)
-- Heads-up display: world name (top-left), gem count (top-right), lock indicator (top-center),
-- notification toast system, chat display with input, player name.
-- Separate ScreenGui (HUDGUI) for ZIndex isolation.

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = require(ReplicatedStorage.Shared)
local RemoteEvents = require(ReplicatedStorage.Shared.RemoteEvents)

local HUD = {}

--[[
	===== CONSTANTS =====
]]
local NOTIFICATION_DURATION = 2.5       -- seconds toast stays visible
local CHAT_FADE_TIME = 8                -- seconds before chat line fades
local MAX_CHAT_LINES = 6

local GEM_COLOR = Color3.fromRGB(255, 215, 0)
local PADLOCK_GREEN = Color3.fromRGB(50, 200, 50)
local PADLOCK_YELLOW = Color3.fromRGB(200, 200, 50)
local PADLOCK_GRAY = Color3.fromRGB(120, 120, 120)
local CHAT_BG_COLOR = Color3.fromRGB(20, 20, 20)

--[[
	===== STATE =====
]]
local screenGui: ScreenGui? = nil
local worldNameLabel: TextLabel? = nil
local gemLabel: TextLabel? = nil
local lockIndicator: Frame? = nil
local playerNameLabel: TextLabel? = nil

-- Notification system
local notifContainer: Frame? = nil
local notifQueue: { { text: string, color: Color3 } } = {}
local currentNotifText: TextLabel? = nil
local currentNotifFrame: Frame? = nil
local notifActive = false

-- Chat system
local chatContainer: Frame? = nil
local chatLines: { TextLabel } = {}            -- Pool of 6 labels
local chatInputBox: TextBox? = nil
local chatInputActive = false
local chatLineTimers: { number } = {}          -- os.clock() time for each line

-- Remote connections
local remoteConnections: { RBXScriptConnection } = {}
local inputConnections: { RBXScriptConnection } = {}

--[[
	===== CREATE NOTIFICATION UI =====
]]
local function createNotificationFrame(): Frame
	local frame = Instance.new("Frame")
	frame.Name = "Notification"
	frame.Size = UDim2.new(0, 280, 0, 32)
	frame.Position = UDim2.new(0.5, -140, 0, 60)  -- top-center, below lock indicator
	frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	frame.BackgroundTransparency = 0.3
	frame.BorderSizePixel = 0
	frame.ZIndex = 20
	frame.Visible = false
	frame.Parent = screenGui

	local label = Instance.new("TextLabel")
	label.Name = "Text"
	label.Size = UDim2.new(1, -16, 1, 0)
	label.Position = UDim2.new(0, 8, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = ""
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextSize = 15
	label.Font = Enum.Font.SourceSansBold
	label.TextXAlignment = Enum.TextXAlignment.Center
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Parent = frame

	return frame
end

--[[
	===== NOTIFICATION SYSTEM =====
]]
local function showNextNotification()
	if #notifQueue == 0 then
		notifActive = false
		if currentNotifFrame then
			currentNotifFrame.Visible = false
		end
		return
	end

	notifActive = true
	local notif = table.remove(notifQueue, 1)

	if not currentNotifFrame or not currentNotifText then
		notifActive = false
		return
	end

	currentNotifText.Text = notif.text
	currentNotifText.TextColor3 = notif.color
	currentNotifFrame.Size = UDim2.new(0, math.clamp(#notif.text * 9 + 40, 120, 400), 0, 32)
	currentNotifFrame.Position = UDim2.new(0.5, -currentNotifFrame.Size.X.Offset / 2, 0, 60)
	currentNotifFrame.Visible = true

	-- Slide in from top
	currentNotifFrame.Position = UDim2.new(0.5, -currentNotifFrame.Size.X.Offset / 2, 0, -10)
	local tween = TweenService:Create(
		currentNotifFrame,
		TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = UDim2.new(0.5, -currentNotifFrame.Size.X.Offset / 2, 0, 60) }
	)
	tween:Play()

	-- Fade out after duration
	task.delay(NOTIFICATION_DURATION, function()
		if not currentNotifFrame then return end
		local fadeOut = TweenService:Create(
			currentNotifFrame,
			TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{ BackgroundTransparency = 1 }
		)
		fadeOut:Play()
		fadeOut.Completed:Once(function()
			if currentNotifFrame then
				currentNotifFrame.Visible = false
				currentNotifFrame.BackgroundTransparency = 0.3
			end
			notifActive = false
			showNextNotification()
		end)
	end)
end

--[[
	===== CHAT SYSTEM =====
]]
local function addChatLine(senderName: string, message: string, textColor: Color3)
	-- Shift lines up (remove oldest)
	if #chatLines >= MAX_CHAT_LINES then
		local oldest = table.remove(chatLines, 1)
		oldest.Text = ""
		oldest.Visible = false
		table.insert(chatLines, oldest)
		table.remove(chatLineTimers, 1)
	end

	-- Find first empty or invisible label to reuse
	local label: TextLabel? = nil
	for _, line in ipairs(chatLines) do
		if line.Text == "" or not line.Visible then
			label = line
			break
		end
	end

	-- If no reusable label, create new one
	if not label then
		label = Instance.new("TextLabel")
		label.Name = "ChatLine"
		label.Size = UDim2.new(0, 400, 0, 18)
		label.BackgroundTransparency = 1
		label.Text = ""
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextSize = 14
		label.Font = Enum.Font.SourceSans
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextYAlignment = Enum.TextYAlignment.Bottom
		label.RichText = true
		label.ZIndex = 5
		label.Parent = chatContainer
		table.insert(chatLines, label)
	end

	-- Set text with sender name colored
	label.Text = `<font color="#{textColor:ToHex()}">{senderName}:</font> {message}`
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.Visible = true
	label.TextTransparency = 0

	-- Position: last line at bottom, others above
	local yOffset = -(#chatLines) * 18
	for i, line in ipairs(chatLines) do
		line.Position = UDim2.new(0, 10, 1, yOffset + (i - 1) * 18)
	end

	-- Fade timer
	local startTime = os.clock()
	table.insert(chatLineTimers, startTime)

	-- After CHAT_FADE_TIME, start fading
	task.delay(CHAT_FADE_TIME - 2, function()
		if not label or label.Text == "" then return end
		local fadeOut = TweenService:Create(
			label,
			TweenInfo.new(2, Enum.EasingStyle.Linear),
			{ TextTransparency = 1 }
		)
		fadeOut:Play()
		fadeOut.Completed:Once(function()
			if label then
				label.Text = ""
				label.Visible = false
				-- Recalculate positions after removal
				repositionChatLines()
			end
		end)
	end)
end

local function repositionChatLines()
	local visibleCount = 0
	for _, line in ipairs(chatLines) do
		if line.Visible then
			visibleCount += 1
		end
	end

	local index = 0
	for _, line in ipairs(chatLines) do
		if line.Visible then
			line.Position = UDim2.new(0, 10, 1, -(visibleCount - index) * 18)
			index += 1
		end
	end
end

local function openChatInput()
	if chatInputActive then return end
	if not chatInputBox then return end

	chatInputActive = true
	chatInputBox.Visible = true
	chatInputBox:CaptureFocus()
	chatInputBox.Text = ""
end

local function closeChatInput()
	if not chatInputActive then return end
	chatInputActive = false
	if chatInputBox then
		chatInputBox.Visible = false
		UserInputService:SetCursorIcon("Arrow")
	end
end

local function sendChatMessage()
	if not chatInputBox then return end

	local message = chatInputBox.Text:match("^%s*(.-)%s*$")  -- trim
	if message and #message > 0 then
		RemoteEvents.RequestChatMessage:FireServer(message)
	end

	closeChatInput()
end

--[[
	===== REMOTE EVENT HANDLERS =====
]]
local function onSpliceResult(tileX: number, tileY: number, success: boolean, resultItemName: string?)
	if success and resultItemName then
		HUD.Notify(`Spliced! Created: {resultItemName}`, Color3.fromRGB(0, 255, 100))
	elseif not success then
		HUD.Notify("Splice failed! Seeds rejected.", Color3.fromRGB(255, 100, 100))
	end
end

local function onWorldLoaded(worldName: string, tileData: any, worldWidth: number, worldHeight: number)
	if worldNameLabel then
		worldNameLabel.Text = worldName:upper()
	end

	-- Reset lock indicator to gray (unlocked) until we hear otherwise
	if lockIndicator then
		lockIndicator.BackgroundColor3 = PADLOCK_GRAY
	end
end

local function onGemsUpdated(gemCount: number)
	if gemLabel then
		gemLabel.Text = `◆ {gemCount}`
	end
end

local function onWorldLockStatus(isLocked: boolean, ownerName: string?)
	if not lockIndicator then return end

	if not isLocked then
		-- Unlocked: gray
		lockIndicator.BackgroundColor3 = PADLOCK_GRAY
	elseif ownerName == Players.LocalPlayer.Name then
		-- Owned by local player: green
		lockIndicator.BackgroundColor3 = PADLOCK_GREEN
	else
		-- Locked by someone else: yellow
		lockIndicator.BackgroundColor3 = PADLOCK_YELLOW
	end
end

local function onChatMessage(senderName: string, message: string, textColor: Color3)
	addChatLine(senderName, message, textColor or Color3.fromRGB(255, 255, 255))
end

--[[
	===== INPUT HANDLING =====
]]
local function onInputBegan(input: InputObject, isProcessed: boolean)
	if isProcessed then return end

	-- If chat input active, handle Enter/Return
	if chatInputActive then
		if input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
			sendChatMessage()
			return true
		elseif input.KeyCode == Enum.KeyCode.Escape then
			closeChatInput()
			return true
		end
		return false
	end

	-- '/' opens chat input (Growtopia style)
	if input.KeyCode == Enum.KeyCode.Slash then
		openChatInput()
		return true
	end

	-- Enter also opens chat
	if input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
		openChatInput()
		return true
	end

	return false
end

--[[
	===== PUBLIC API =====
]]

--[[
	Initialize HUD: create all labels, indicators, chat system, and connect remotes.
]]
function HUD.Init()
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "HUDGUI"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

	--[[ TOP-LEFT: World Name ]]
	worldNameLabel = Instance.new("TextLabel")
	worldNameLabel.Name = "WorldName"
	worldNameLabel.Size = UDim2.new(0, 200, 0, 22)
	worldNameLabel.Position = UDim2.new(0, 10, 0, 8)
	worldNameLabel.BackgroundTransparency = 0.4
	worldNameLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	worldNameLabel.Text = "START"
	worldNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	worldNameLabel.TextSize = 16
	worldNameLabel.Font = Enum.Font.SourceSansBold
	worldNameLabel.TextXAlignment = Enum.TextXAlignment.Left
	worldNameLabel.ZIndex = 2
	worldNameLabel.Parent = screenGui

	--[[ TOP-CENTER: Lock Indicator ]]
	lockIndicator = Instance.new("Frame")
	lockIndicator.Name = "LockIndicator"
	lockIndicator.Size = UDim2.new(0, 14, 0, 18)
	lockIndicator.Position = UDim2.new(0.5, -7, 0, 8)
	lockIndicator.BackgroundColor3 = PADLOCK_GRAY
	lockIndicator.BackgroundTransparency = 0
	lockIndicator.BorderSizePixel = 0
	lockIndicator.ZIndex = 2
	lockIndicator.Parent = screenGui

	-- Small lock icon text
	local lockLabel = Instance.new("TextLabel")
	lockLabel.Name = "LockIcon"
	lockLabel.Size = UDim2.new(1, 0, 1, 0)
	lockLabel.BackgroundTransparency = 1
	lockLabel.Text = "🔒"
	lockLabel.TextSize = 12
	lockLabel.Font = Enum.Font.SourceSansBold
	lockLabel.TextXAlignment = Enum.TextXAlignment.Center
	lockLabel.TextYAlignment = Enum.TextYAlignment.Center
	lockLabel.Parent = lockIndicator

	--[[ TOP-RIGHT: Gem Counter ]]
	gemLabel = Instance.new("TextLabel")
	gemLabel.Name = "GemCounter"
	gemLabel.Size = UDim2.new(0, 110, 0, 24)
	gemLabel.Position = UDim2.new(1, -120, 0, 8)
	gemLabel.BackgroundTransparency = 0.4
	gemLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	gemLabel.Text = "◆ 0"
	gemLabel.TextColor3 = GEM_COLOR
	gemLabel.TextSize = 16
	gemLabel.Font = Enum.Font.SourceSansBold
	gemLabel.TextXAlignment = Enum.TextXAlignment.Right
	gemLabel.ZIndex = 2
	gemLabel.Parent = screenGui

	--[[ NOTIFICATION SYSTEM ]]
	notifContainer = Instance.new("Frame")
	notifContainer.Name = "NotificationContainer"
	notifContainer.Size = UDim2.new(0, 400, 0, 100)
	notifContainer.Position = UDim2.new(0.5, -200, 0, 50)
	notifContainer.BackgroundTransparency = 1
	notifContainer.BorderSizePixel = 0
	notifContainer.ZIndex = 20
	notifContainer.Parent = screenGui

	-- Create the notification frame (reused)
	currentNotifFrame = createNotificationFrame()
	currentNotifText = currentNotifFrame:FindFirstChild("Text") :: TextLabel

	--[[ CHAT SYSTEM ]]
	chatContainer = Instance.new("Frame")
	chatContainer.Name = "ChatContainer"
	chatContainer.Size = UDim2.new(0, 420, 0, MAX_CHAT_LINES * 18 + 8)
	chatContainer.Position = UDim2.new(0, 10, 1, -(MAX_CHAT_LINES * 18) - 20 - 70)  -- Above hotbar
	chatContainer.BackgroundTransparency = 0.3
	chatContainer.BackgroundColor3 = CHAT_BG_COLOR
	chatContainer.BorderSizePixel = 0
	chatContainer.ZIndex = 4
	chatContainer.Parent = screenGui

	-- Create pooled chat labels (pre-create MAX_CHAT_LINES)
	for i = 1, MAX_CHAT_LINES do
		local label = Instance.new("TextLabel")
		label.Name = "ChatLine" .. i
		label.Size = UDim2.new(0, 400, 0, 18)
		label.Position = UDim2.new(0, 10, 1, -(i * 18))
		label.BackgroundTransparency = 1
		label.Text = ""
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextSize = 14
		label.Font = Enum.Font.SourceSans
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextYAlignment = Enum.TextYAlignment.Bottom
		label.RichText = true
		label.ZIndex = 5
		label.Visible = false
		label.Parent = chatContainer
		table.insert(chatLines, label)
	end

	-- Chat input box (hidden until activated)
	chatInputBox = Instance.new("TextBox")
	chatInputBox.Name = "ChatInput"
	chatInputBox.Size = UDim2.new(0, 400, 0, 26)
	chatInputBox.Position = UDim2.new(0, 10, 1, -(MAX_CHAT_LINES * 18) - 20 - 70 - 30)  -- Below chat
	chatInputBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	chatInputBox.BackgroundTransparency = 0.2
	chatInputBox.BorderSizePixel = 1
	chatInputBox.BorderColor3 = Color3.fromRGB(80, 80, 80)
	chatInputBox.Text = ""
	chatInputBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	chatInputBox.TextSize = 15
	chatInputBox.Font = Enum.Font.SourceSans
	chatInputBox.PlaceholderText = "Type a message..."
	chatInputBox.ClearTextOnFocus = false
	chatInputBox.ZIndex = 6
	chatInputBox.Visible = false
	chatInputBox.Parent = screenGui

	-- Handle Enter in input box to send
	chatInputBox.FocusLost:Connect(function(enterPressed: boolean)
		if enterPressed then
			sendChatMessage()
		else
			closeChatInput()
		end
	end)

	--[[ REMOTE EVENT CONNECTIONS ]]
	local conn1 = RemoteEvents.SpliceResult.OnClientEvent:Connect(onSpliceResult)
	table.insert(remoteConnections, conn1)

	local conn2 = RemoteEvents.WorldLoaded.OnClientEvent:Connect(onWorldLoaded)
	table.insert(remoteConnections, conn2)

	local conn3 = RemoteEvents.GemsUpdated.OnClientEvent:Connect(onGemsUpdated)
	table.insert(remoteConnections, conn3)

	local conn4 = RemoteEvents.WorldLockStatus.OnClientEvent:Connect(onWorldLockStatus)
	table.insert(remoteConnections, conn4)

	local conn5 = RemoteEvents.ChatMessage.OnClientEvent:Connect(onChatMessage)
	table.insert(remoteConnections, conn5)

	--[[ INPUT CONNECTIONS ]]
	local conn6 = UserInputService.InputBegan:Connect(onInputBegan)
	table.insert(inputConnections, conn6)

	print("[HUD] Initialized")
end

--[[
	Show a notification toast.
	Queues if one is already active.
	@param message: string — text to display
	@param color: Color3 — text color
]]
function HUD.Notify(message: string, color: Color3?)
	color = color or Color3.fromRGB(255, 255, 255)
	table.insert(notifQueue, { text = message, color = color })

	if not notifActive then
		showNextNotification()
	end
end

--[[
	Set gem count display.
	@param count: number
]]
function HUD.SetGems(count: number)
	if gemLabel then
		gemLabel.Text = `◆ {count}`
	end
end

--[[
	Set world name display.
	@param name: string
]]
function HUD.SetWorldName(name: string)
	if worldNameLabel then
		worldNameLabel.Text = name:upper()
	end
end

--[[
	Clean up all GUI and connections.
]]
function HUD.Destroy()
	for _, conn in ipairs(remoteConnections) do
		conn:Disconnect()
	end
	for _, conn in ipairs(inputConnections) do
		conn:Disconnect()
	end
	if screenGui then
		screenGui:Destroy()
		screenGui = nil
	end
	chatLines = {}
	notifQueue = {}
	print("[HUD] Destroyed")
end

return HUD
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="35">
            <Properties>
              <string name="Name">Hotbar</string>
              <string name="Source"><![CDATA[-- HotbarUI.lua (client)
-- Growtopia-style 9-slot item hotbar at bottom-center of screen.
-- Each slot: 56×56px, dark bg, 2px border, item color fill, count label, slot number.
-- Selected slot: bright white border, slight scale-up (1.05) via TweenService.
-- Hover: tooltip Frame above slot showing item name.
-- Listens to Remotes.InventoryUpdated and updates automatically.

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = require(ReplicatedStorage.Shared)
local ItemDatabase = Shared.ItemDatabase
local RemoteEvents = require(ReplicatedStorage.Shared.RemoteEvents)

local Hotbar = {}

--[[
	===== CONSTANTS =====
]]
local SLOT_COUNT = 9
local SLOT_SIZE = 56
local SLOT_GAP = 4
local HOTBAR_WIDTH = SLOT_COUNT * SLOT_SIZE + (SLOT_COUNT - 1) * SLOT_GAP
local BORDER_SELECTED = Color3.fromRGB(255, 255, 255)
local BORDER_DEFAULT = Color3.fromRGB(80, 80, 80)
local BG_COLOR = Color3.fromRGB(30, 30, 30)
local BG_EMPTY = Color3.fromRGB(50, 50, 50)

--[[
	===== STATE =====
]]
local screenGui: ScreenGui? = nil
local hotbarFrame: Frame? = nil
local slotFrames: { Frame } = {}
local slotData: { { itemId: number, count: number }? } = {}  -- slotIndex → data
local selectedSlot = 1
local tweenIn: Tween? = nil
local tweenOut: Tween? = nil
local tooltipFrame: Frame? = nil
local tooltipLabel: TextLabel? = nil

-- Remote connections for cleanup (disconnected on world change, reconnected)
local remoteConnections: { RBXScriptConnection } = {}

--[[
	===== CREATE SLOT UI =====
]]
local function createSlotContainer(index: number): Frame
	local slot = Instance.new("Frame")
	slot.Name = "Slot" .. index
	slot.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
	slot.Position = UDim2.new(0, (index - 1) * (SLOT_SIZE + SLOT_GAP), 0, 0)
	slot.BackgroundColor3 = BG_COLOR
	slot.BackgroundTransparency = 0.3
	slot.BorderSizePixel = 2
	slot.BorderColor3 = BORDER_DEFAULT
	slot.ClipsDescendants = true
	slot.Parent = hotbarFrame

	-- Item color fill
	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.Size = UDim2.new(0, SLOT_SIZE - 8, 0, SLOT_SIZE - 8)
	fill.Position = UDim2.new(0, 4, 0, 4)
	fill.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
	fill.BorderSizePixel = 0
	fill.Parent = slot

	-- Slot number (top-left)
	local numLabel = Instance.new("TextLabel")
	numLabel.Name = "Number"
	numLabel.Size = UDim2.new(0, 16, 0, 14)
	numLabel.Position = UDim2.new(0, 2, 0, 2)
	numLabel.BackgroundTransparency = 1
	numLabel.Text = tostring(index)
	numLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
	numLabel.TextSize = 11
	numLabel.Font = Enum.Font.SourceSansBold
	numLabel.TextXAlignment = Enum.TextXAlignment.Left
	numLabel.Parent = slot

	-- Item count (bottom-right)
	local countLabel = Instance.new("TextLabel")
	countLabel.Name = "Count"
	countLabel.Size = UDim2.new(0, 40, 0, 16)
	countLabel.Position = UDim2.new(1, -42, 1, -18)
	countLabel.BackgroundTransparency = 1
	countLabel.Text = ""
	countLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	countLabel.TextSize = 13
	countLabel.Font = Enum.Font.SourceSansBold
	countLabel.TextXAlignment = Enum.TextXAlignment.Right
	countLabel.Parent = slot

	return slot
end

--[[
	===== TOOLTIP =====
]]
local function showTooltip(slotIndex: number)
	local data = slotData[slotIndex]
	if not data or data.itemId == 0 then
		if tooltipFrame then
			tooltipFrame.Visible = false
		end
		return
	end

	if not tooltipFrame then return end

	local slot = slotFrames[slotIndex]
	if not slot then return end

	local item = ItemDatabase.GetItem(data.itemId)
	if not item then
		tooltipFrame.Visible = false
		return
	end

	-- Position tooltip above slot
	local absPos = slot.AbsolutePosition
	tooltipFrame.Position = UDim2.new(0, absPos.X - 40, 0, absPos.Y - 36)
	tooltipFrame.Size = UDim2.new(0, 136, 0, 24)

	if tooltipLabel then
		tooltipLabel.Text = item.name
	end

	tooltipFrame.Visible = true
end

local function hideTooltip()
	if tooltipFrame then
		tooltipFrame.Visible = false
	end
end

--[[
	===== UPDATE SLOT VISUALS =====
]]
local function updateSlot(slotIndex: number)
	local slot = slotFrames[slotIndex]
	if not slot then return end

	local fill = slot:FindFirstChild("Fill") :: Frame
	local countLabel = slot:FindFirstChild("Count") :: TextLabel
	if not fill or not countLabel then return end

	local data = slotData[slotIndex]
	if data and data.itemId and data.itemId > 0 then
		local item = ItemDatabase.GetItem(data.itemId)
		local color = item and item.color or Color3.fromRGB(100, 100, 100)
		fill.BackgroundColor3 = color

		if data.count > 1 then
			countLabel.Text = tostring(data.count)
			countLabel.Visible = true
		else
			countLabel.Text = ""
			countLabel.Visible = false
		end
	else
		fill.BackgroundColor3 = BG_EMPTY
		countLabel.Text = ""
		countLabel.Visible = false
	end
end

--[[
	===== UPDATE SELECTION HIGHLIGHT =====
]]
local function updateSelection(slotIndex: number)
	for i, slot in ipairs(slotFrames) do
		if i == slotIndex then
			-- Cancel any existing tween on this slot
			if tweenIn then
				tweenIn:Cancel()
			end
			if tweenOut then
				tweenOut:Cancel()
			end

			slot.BorderColor3 = BORDER_SELECTED
			slot.BorderSizePixel = 2

			-- Scale up by 1.05
			local scaleOut = {
				Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE),
				Position = UDim2.new(0, (i - 1) * (SLOT_SIZE + SLOT_GAP), 0, 0),
			}
			local scaleIn = {
				Size = UDim2.new(0, SLOT_SIZE * 1.05, 0, SLOT_SIZE * 1.05),
				Position = UDim2.new(
					0, (i - 1) * (SLOT_SIZE + SLOT_GAP) - math.floor(SLOT_SIZE * 0.025),
					0, -math.floor(SLOT_SIZE * 0.025)
				),
			}

			tweenOut = TweenService:Create(slot, TweenInfo.new(0.04, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), scaleIn)
			tweenOut:Play()
			tweenOut.Completed:Once(function()
				tweenIn = TweenService:Create(slot, TweenInfo.new(0.04, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), scaleOut)
				tweenIn:Play()
			end)
		else
			slot.BorderColor3 = BORDER_DEFAULT
			slot.BorderSizePixel = 1
			slot.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
			slot.Position = UDim2.new(0, (i - 1) * (SLOT_SIZE + SLOT_GAP), 0, 0)
		end
	end
end

--[[
	===== FULL RE-RENDER =====
]]
local function renderAllSlots()
	for i = 1, SLOT_COUNT do
		updateSlot(i)
	end
	updateSelection(selectedSlot)
end

--[[
	===== INVENTORY LISTENER =====
]]
local function onInventoryUpdated(inventoryTable: { { itemId: number, count: number }? })
	-- Clear all slot data first
	for i = 1, SLOT_COUNT do
		slotData[i] = nil
	end

	-- Copy slots 1-9 from inventory
	for i = 1, math.min(#inventoryTable, SLOT_COUNT) do
		local invSlot = inventoryTable[i]
		if invSlot and invSlot.itemId and invSlot.itemId > 0 then
			slotData[i] = { itemId = invSlot.itemId, count = invSlot.count }
		end
	end

	renderAllSlots()
end

--[[
	===== PUBLIC API =====
]]

--[[
	Initialize HotbarUI.
	Creates ScreenGui, 9 slots, tooltip, and connects to inventory updates.
]]
function Hotbar.Init()
	-- Create ScreenGui
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "HotbarGUI"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

	-- Tooltip frame (parent to gui but hidden)
	tooltipFrame = Instance.new("Frame")
	tooltipFrame.Name = "HotbarTooltip"
	tooltipFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	tooltipFrame.BackgroundTransparency = 0.15
	tooltipFrame.BorderSizePixel = 1
	tooltipFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
	tooltipFrame.ZIndex = 100
	tooltipFrame.Visible = false
	tooltipFrame.Parent = screenGui

	tooltipLabel = Instance.new("TextLabel")
	tooltipLabel.Name = "TooltipText"
	tooltipLabel.Size = UDim2.new(1, 0, 1, 0)
	tooltipLabel.BackgroundTransparency = 1
	tooltipLabel.Text = ""
	tooltipLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	tooltipLabel.TextSize = 14
	tooltipLabel.Font = Enum.Font.SourceSansBold
	tooltipLabel.TextXAlignment = Enum.TextXAlignment.Center
	tooltipLabel.TextYAlignment = Enum.TextYAlignment.Center
	tooltipLabel.Parent = tooltipFrame

	-- Hotbar container frame
	hotbarFrame = Instance.new("Frame")
	hotbarFrame.Name = "Hotbar"
	hotbarFrame.Size = UDim2.new(0, HOTBAR_WIDTH, 0, SLOT_SIZE)
	hotbarFrame.Position = UDim2.new(0.5, -math.floor(HOTBAR_WIDTH / 2), 1, -SLOT_SIZE - 8)
	hotbarFrame.BackgroundTransparency = 1
	hotbarFrame.BorderSizePixel = 0
	hotbarFrame.Parent = screenGui

	-- Create 9 slots
	for i = 1, SLOT_COUNT do
		local slot = createSlotContainer(i)

		-- Mouse enter/leave for tooltip
		slot.MouseEnter:Connect(function()
			showTooltip(i)
		end)
		slot.MouseLeave:Connect(function()
			hideTooltip()
		end)

		slotFrames[i] = slot
	end

	-- Listen for inventory updates
	local conn = RemoteEvents.InventoryUpdated.OnClientEvent:Connect(onInventoryUpdated)
	table.insert(remoteConnections, conn)

	-- Initial render
	renderAllSlots()

	print("[Hotbar] Initialized")
end

--[[
	Set which slot is visually selected.
	@param slotIndex: number — 1 to 9
]]
function Hotbar.SetSelectedSlot(slotIndex: number)
	slotIndex = math.clamp(slotIndex, 1, SLOT_COUNT)
	selectedSlot = slotIndex
	updateSelection(slotIndex)
end

--[[
	Update a single slot's data and display without full re-render.
	@param slotIndex: number — 1 to 9
	@param itemId: number — 0 = empty
	@param count: number
]]
function Hotbar.UpdateSlot(slotIndex: number, itemId: number, count: number)
	if slotIndex < 1 or slotIndex > SLOT_COUNT then return end

	if itemId and itemId > 0 then
		slotData[slotIndex] = { itemId = itemId, count = count }
	else
		slotData[slotIndex] = nil
	end

	updateSlot(slotIndex)
end

--[[
	Re-render all slots from a full inventory table.
	@param inventoryTable: { { itemId: number, count: number }? }
]]
function Hotbar.UpdateInventory(inventoryTable: { { itemId: number, count: number }? })
	onInventoryUpdated(inventoryTable)
end

--[[
	Get the current selected slot index.
	@return slotIndex: number
]]
function Hotbar.GetSelectedSlot(): number
	return selectedSlot
end

--[[
	Get item data for a slot.
	@param slotIndex: number
	@return { itemId: number, count: number }?
]]
function Hotbar.GetSlotData(slotIndex: number): { itemId: number, count: number }?
	return slotData[slotIndex]
end

--[[
	Clean up all GUI and connections.
]]
function Hotbar.Destroy()
	for _, conn in ipairs(remoteConnections) do
		conn:Disconnect()
	end
	if screenGui then
		screenGui:Destroy()
		screenGui = nil
	end
	slotFrames = {}
	slotData = {}
	print("[Hotbar] Destroyed")
end

return Hotbar
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="36">
            <Properties>
              <string name="Name">InventoryGUI</string>
              <string name="Source"><![CDATA[-- InventoryGUI.luau (client)
-- Full inventory screen: 8 columns × 4 rows = 32 slots, toggled with Tab.
-- Drag-and-drop: pick up item, swap with another slot.
-- Tooltip on hover: item name + description.
-- Animated slide-in from bottom (TweenService, 0.15s).
-- Gem display bottom-left, close button top-right.
-- Separate ScreenGui (InventoryGUI) to avoid ZIndex conflicts.

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = require(ReplicatedStorage.Shared)
local ItemDatabase = Shared.ItemDatabase
local RemoteEvents = require(ReplicatedStorage.Shared.RemoteEvents)

local InventoryGUI = {}

--[[
	===== CONSTANTS =====
]]
local COLS = 8
local ROWS = 4
local TOTAL_SLOTS = COLS * ROWS  -- 32
local SLOT_SIZE = 52
local SLOT_GAP = 4
local PANEL_WIDTH = COLS * (SLOT_SIZE + SLOT_GAP) + 40      -- ~488px
local PANEL_HEIGHT = ROWS * (SLOT_SIZE + SLOT_GAP) + 120     -- ~364px
local BG_TRANSPARENCY = 0.5

local BG_COLOR = Color3.fromRGB(40, 40, 50)
local SLOT_BG = Color3.fromRGB(60, 60, 70)
local EMPTY_COLOR = Color3.fromRGB(100, 100, 100)
local GEM_YELLOW = Color3.fromRGB(255, 215, 0)

--[[
	===== STATE =====
]]
local screenGui: ScreenGui? = nil
local panel: Frame? = nil
local panelTween: Tween? = nil
local isOpen = false
local slotFrames: { Frame } = {}          -- slotIndex 1..32 → Frame
local slotData: { { itemId: number, count: number }? } = {}  -- in-game slot index → data
local gemCount = 0

-- Drag state
local dragSlotIndex: number? = nil
local dragFrame: Frame? = nil
local dragItemId = 0
local dragCount = 0
local isDragging = false

-- Tooltip state
local tooltipFrame: Frame? = nil
local tooltipName: TextLabel? = nil
local tooltipDesc: TextLabel? = nil

-- Connection cleanup
local remoteConnections: { RBXScriptConnection } = {}
local inputConnections: { RBXScriptConnection } = {}

--[[
	===== CREATE INVENTORY SLOT =====
]]
local function createSlot(index: number, parent: Frame): ImageButton
	local slot = Instance.new("ImageButton")
	slot.BackgroundColor3 = SLOT_BG
	slot.BorderSizePixel = 1
	slot.BorderColor3 = Color3.fromRGB(80, 80, 80)
	slot.ImageTransparency = 1  -- transparent image, acts like a Frame with click events
	slot.Name = "Slot" .. index
	slot.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)

	-- Item fill
	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.Size = UDim2.new(0, SLOT_SIZE - 6, 0, SLOT_SIZE - 6)
	fill.Position = UDim2.new(0, 3, 0, 3)
	fill.BackgroundColor3 = EMPTY_COLOR
	fill.BorderSizePixel = 0
	fill.Parent = slot

	-- Count label
	local countLabel = Instance.new("TextLabel")
	countLabel.Name = "Count"
	countLabel.Size = UDim2.new(0, 36, 0, 14)
	countLabel.Position = UDim2.new(1, -38, 1, -16)
	countLabel.BackgroundTransparency = 1
	countLabel.Text = ""
	countLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	countLabel.TextSize = 12
	countLabel.Font = Enum.Font.SourceSansBold
	countLabel.TextXAlignment = Enum.TextXAlignment.Right
	countLabel.Parent = slot

	slot.Parent = parent
	return slot
end
--[[
	===== SLOT RENDERING =====
]]

local function updateSlot(slotIndex: number)
	local slot = slotFrames[slotIndex]
	if not slot then return end

	local fill = slot:FindFirstChild("Fill") :: Frame
	local countLabel = slot:FindFirstChild("Count") :: TextLabel
	if not fill or not countLabel then return end

	local data = slotData[slotIndex]
	if data and data.itemId and data.itemId > 0 then
		local item = ItemDatabase.GetItem(data.itemId)
		local color = item and item.color or EMPTY_COLOR
		fill.BackgroundColor3 = color

		if data.count > 1 then
			countLabel.Text = tostring(data.count)
			countLabel.Visible = true
		else
			countLabel.Text = ""
			countLabel.Visible = false
		end
	else
		fill.BackgroundColor3 = EMPTY_COLOR
		countLabel.Text = ""
		countLabel.Visible = false
	end
end

--[[
	===== CREATE UI =====
]]

local function buildUI()
	if not screenGui or not panel then return end

	-- Clear previous content (keep dragger)
	for _, child in ipairs(panel:GetChildren()) do
		if child.Name ~= "Dragger" and child.Name ~= "TooltipBg" then
			child:Destroy()
		end
	end

	slotFrames = {}

	-- Background overlay
	local overlay = Instance.new("Frame")
	overlay.Name = "Overlay"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	overlay.BackgroundTransparency = BG_TRANSPARENCY
	overlay.BorderSizePixel = 0
	overlay.ZIndex = 1
	overlay.Parent = panel

	-- INNER PANEL (white card)
	local inner = Instance.new("Frame")
	inner.Name = "Inner"
	inner.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
	inner.Position = UDim2.new(0.5, -math.floor(PANEL_WIDTH / 2), 0.5, -math.floor(PANEL_HEIGHT / 2))
	inner.BackgroundColor3 = BG_COLOR
	inner.BorderSizePixel = 1
	inner.BorderColor3 = Color3.fromRGB(80, 80, 80)
	inner.ZIndex = 2
	inner.Parent = panel

	-- Close button (X) top-right
	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseBtn"
	closeBtn.Size = UDim2.new(0, 28, 0, 28)
	closeBtn.Position = UDim2.new(1, -34, 0, 6)
	closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	closeBtn.BackgroundTransparency = 0.2
	closeBtn.Text = "X"
	closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	closeBtn.TextSize = 16
	closeBtn.Font = Enum.Font.SourceSansBold
	closeBtn.ZIndex = 10
	closeBtn.Parent = inner
	closeBtn.MouseButton1Click:Connect(function()
		InventoryGUI.Close()
	end)

	-- Title
	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(0, 160, 0, 30)
	title.Position = UDim2.new(0, 12, 0, 8)
	title.BackgroundTransparency = 1
	title.Text = "BACKPACK"
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextSize = 18
	title.Font = Enum.Font.SourceSansBold
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.ZIndex = 5
	title.Parent = inner

	-- Grid container
	local gridFrame = Instance.new("Frame")
	gridFrame.Name = "GridFrame"
	gridFrame.Size = UDim2.new(0, COLS * (SLOT_SIZE + SLOT_GAP) - SLOT_GAP, 0, ROWS * (SLOT_SIZE + SLOT_GAP) - SLOT_GAP)
	gridFrame.Position = UDim2.new(0, 20, 0, 44)
	gridFrame.BackgroundTransparency = 1
	gridFrame.BorderSizePixel = 0
	gridFrame.ZIndex = 3
	gridFrame.Parent = inner

	-- UIGridLayout
	local gridLayout = Instance.new("UIGridLayout")
	gridLayout.Name = "GridLayout"
	gridLayout.CellSize = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
	gridLayout.CellPadding = UDim2.new(0, SLOT_GAP, 0, SLOT_GAP)
	gridLayout.FillDirection = Enum.FillDirection.Horizontal
	gridLayout.StartCorner = Enum.StartCorner.TopLeft
	gridLayout.Parent = gridFrame

	-- Gem display (bottom-left)
	local gemFrame = Instance.new("Frame")
	gemFrame.Name = "GemFrame"
	gemFrame.Size = UDim2.new(0, 120, 0, 24)
	gemFrame.Position = UDim2.new(0, 14, 1, -34)
	gemFrame.BackgroundTransparency = 1
	gemFrame.ZIndex = 5
	gemFrame.Parent = inner

	local gemIcon = Instance.new("Frame")
	gemIcon.Name = "GemIcon"
	gemIcon.Size = UDim2.new(0, 18, 0, 18)
	gemIcon.Position = UDim2.new(0, 0, 0, 3)
	gemIcon.BackgroundColor3 = GEM_YELLOW
	gemIcon.BorderSizePixel = 0
	gemIcon.ZIndex = 6
	gemIcon.Parent = gemFrame

	local gemLabel = Instance.new("TextLabel")
	gemLabel.Name = "GemCount"
	gemLabel.Size = UDim2.new(0, 90, 0, 24)
	gemLabel.Position = UDim2.new(0, 24, 0, 0)
	gemLabel.BackgroundTransparency = 1
	gemLabel.Text = tostring(gemCount)
	gemLabel.TextColor3 = GEM_YELLOW
	gemLabel.TextSize = 16
	gemLabel.Font = Enum.Font.SourceSansBold
	gemLabel.TextXAlignment = Enum.TextXAlignment.Left
	gemLabel.ZIndex = 6
	gemLabel.Parent = gemFrame

	-- Create slots
	for i = 1, TOTAL_SLOTS do
		local slot = createSlot(i, gridFrame)

		-- Mouse events for drag and tooltip
		slot.MouseButton1Down:Connect(function()
			if isDragging then return end
			if not dragSlotIndex then
				local data = slotData[i]
				if data and data.itemId and data.itemId > 0 then
					startDrag(i, data.itemId, data.count)
				end
			end
		end)

		slot.MouseButton1Up:Connect(function()
			if isDragging and dragSlotIndex and dragSlotIndex ~= i then
				endDrag(i)
			end
		end)

		slot.MouseEnter:Connect(function()
			showTooltip(i)
		end)
		slot.MouseLeave:Connect(function()
			hideTooltip()
		end)

		slotFrames[i] = slot
	end

	-- Tooltip (parent to inner)
	if not tooltipFrame then
		tooltipFrame = Instance.new("Frame")
		tooltipFrame.Name = "TooltipBg"
		tooltipFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
		tooltipFrame.BackgroundTransparency = 0.15
		tooltipFrame.BorderSizePixel = 1
		tooltipFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
		tooltipFrame.ZIndex = 20
		tooltipFrame.Visible = false

		tooltipName = Instance.new("TextLabel")
		tooltipName.Name = "TooltipName"
		tooltipName.Size = UDim2.new(1, -8, 0, 18)
		tooltipName.Position = UDim2.new(0, 4, 0, 4)
		tooltipName.BackgroundTransparency = 1
		tooltipName.Text = ""
		tooltipName.TextColor3 = Color3.fromRGB(255, 255, 255)
		tooltipName.TextSize = 14
		tooltipName.Font = Enum.Font.SourceSansBold
		tooltipName.TextXAlignment = Enum.TextXAlignment.Left
		tooltipName.Parent = tooltipFrame

		tooltipDesc = Instance.new("TextLabel")
		tooltipDesc.Name = "TooltipDesc"
		tooltipDesc.Size = UDim2.new(1, -8, 0, 14)
		tooltipDesc.Position = UDim2.new(0, 4, 0, 22)
		tooltipDesc.BackgroundTransparency = 1
		tooltipDesc.Text = ""
		tooltipDesc.TextColor3 = Color3.fromRGB(180, 180, 180)
		tooltipDesc.TextSize = 11
		tooltipDesc.Font = Enum.Font.SourceSans
		tooltipDesc.TextXAlignment = Enum.TextXAlignment.Left
		tooltipDesc.Parent = tooltipFrame
	end
	tooltipFrame.Parent = inner

	-- Dragger Frame (already created in Init)
	if not dragFrame then
		dragFrame = Instance.new("Frame")
		dragFrame.Name = "Dragger"
		dragFrame.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
		dragFrame.BackgroundColor3 = EMPTY_COLOR
		dragFrame.BorderSizePixel = 1
		dragFrame.BorderColor3 = Color3.fromRGB(200, 200, 200)
		dragFrame.ZIndex = 30
		dragFrame.Visible = false
		-- Dragger is parented to screenGui, not panel
	end

	-- Render all slots
	for i = 1, TOTAL_SLOTS do
		updateSlot(i)
	end

	-- Update gem display
	local inner = panel and panel:FindFirstChild("Inner")
	if inner then
		local gemFrame = inner:FindFirstChild("GemFrame")
		if gemFrame then
			local gemLabel = gemFrame:FindFirstChild("GemCount") :: TextLabel
			if gemLabel then
				gemLabel.Text = tostring(gemCount)
			end
		end
	end
end

--[[
	===== DRAG & DROP =====
]]
local function startDrag(slotIndex: number, itemId: number, count: number)
	if not dragFrame or not screenGui then return end

	dragSlotIndex = slotIndex
	dragItemId = itemId
	dragCount = count
	isDragging = true

	local item = ItemDatabase.GetItem(itemId)
	local color = item and item.color or EMPTY_COLOR

	dragFrame.BackgroundColor3 = color
	dragFrame.Visible = true
	dragFrame.Parent = screenGui  -- ensure top-level in gui

	-- Position at cursor
	local mousePos = UserInputService:GetMouseLocation()
	dragFrame.Position = UDim2.new(0, mousePos.X - SLOT_SIZE / 2, 0, mousePos.Y - SLOT_SIZE / 2)
end

local function endDrag(targetSlotIndex: number)
	if not dragSlotIndex then return end

	if dragSlotIndex == targetSlotIndex then
		cancelDrag()
		return
	end

	-- Fire swap request to server
	RemoteEvents.RequestSwapSlots:FireServer(dragSlotIndex, targetSlotIndex)
	cancelDrag()
end

local function cancelDrag()
	isDragging = false
	dragSlotIndex = nil
	dragItemId = 0
	dragCount = 0
	if dragFrame then
		dragFrame.Visible = false
	end
end

--[[
	===== TOOLTIP =====
]]
local function showTooltip(slotIndex: number)
	local data = slotData[slotIndex]
	if not data or not data.itemId or data.itemId == 0 then
		hideTooltip()
		return
	end
	if not tooltipFrame or not tooltipName or not tooltipDesc then return end

	local item = ItemDatabase.GetItem(data.itemId)
	if not item then return end

	tooltipName.Text = item.name
	tooltipDesc.Text = item.description or ""

	-- Position tooltip (slightly right of cursor)
	local mousePos = UserInputService:GetMouseLocation()
	local tooltipW = 200
	tooltipFrame.Size = UDim2.new(0, tooltipW, 0, 40)
	tooltipFrame.Position = UDim2.new(0, mousePos.X + 16, 0, mousePos.Y - 20)
	tooltipFrame.Visible = true
end

local function hideTooltip()
	if tooltipFrame then
		tooltipFrame.Visible = false
	end
end
local function renderAllSlots()
	for i = 1, TOTAL_SLOTS do
		updateSlot(i)
	end

	-- Update gem display
	local inner = panel and panel:FindFirstChild("Inner")
	if inner then
		local gemFrame = inner:FindFirstChild("GemFrame")
		if gemFrame then
			local gemLabel = gemFrame:FindFirstChild("GemCount") :: TextLabel
			if gemLabel then
				gemLabel.Text = tostring(gemCount)
			end
		end
	end
end

--[[
	===== INVENTORY LISTENER =====
]]
local function onInventoryUpdated(inventoryTable: { { itemId: number, count: number }? })
	-- Clear
	for i = 1, TOTAL_SLOTS do
		slotData[i] = nil
	end

	-- Fill from inventory (server sends 32 slots)
	for i = 1, math.min(#inventoryTable, TOTAL_SLOTS) do
		local invSlot = inventoryTable[i]
		if invSlot and invSlot.itemId and invSlot.itemId > 0 then
			slotData[i] = { itemId = invSlot.itemId, count = invSlot.count }
		end
	end

	if isOpen then
		renderAllSlots()
	end
end

--[[
	===== GEM LISTENER =====
]]
local function onGemsUpdated(newGemCount: number)
	gemCount = newGemCount
	if isOpen then
		local inner = panel and panel:FindFirstChild("Inner")
		if inner then
			local gemFrame = inner:FindFirstChild("GemFrame")
			if gemFrame then
				local gemLabel = gemFrame:FindFirstChild("GemCount") :: TextLabel
				if gemLabel then
					gemLabel.Text = tostring(gemCount)
				end
			end
		end
	end
end

--[[
	===== WORLD CHANGE CLEANUP =====
]]
local function onWorldLoaded()
	-- Cancel any active drag
	cancelDrag()
	if isOpen then
		closePanel()
	end
end

--[[
	===== ANIMATE PANEL =====
]]
local function openPanel()
	if not panel then return end

	panel.Visible = true
	panel.Position = UDim2.new(0, 0, 1, 0)  -- start off-screen bottom

	if panelTween then
		panelTween:Cancel()
	end
	panelTween = TweenService:Create(
		panel,
		TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = UDim2.new(0, 0, 0, 0) }
	)
	panelTween:Play()
end

local function closePanel()
	if not panel then return end

	if panelTween then
		panelTween:Cancel()
	end
	panelTween = TweenService:Create(
		panel,
		TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = UDim2.new(0, 0, 1, 0) }
	)
	panelTween:Play()
	panelTween.Completed:Once(function()
		panel.Visible = false
	end)
end

--[[
	===== INPUT HANDLING =====
]]
local function onInputBegan(input: InputObject, isProcessed: boolean)
	if isProcessed then return end

	-- Tab toggle
	if input.KeyCode == Enum.KeyCode.Tab then
		if isOpen then
			InventoryGUI.Close()
		else
			InventoryGUI.Open()
		end
		return true
	end

	-- Cancel drag via right-click
	if input.UserInputType == Enum.UserInputType.MouseButton2 and isDragging then
		cancelDrag()
		return true
	end

	-- If inventory open and click outside panel, close
	if isOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
		local mousePos = UserInputService:GetMouseLocation()
		local inner = panel and panel:FindFirstChild("Inner")
		if inner then
			local absPos = inner.AbsolutePosition
			local absSize = inner.AbsoluteSize
			local within = mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X
				and mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y
			if not within then
				closePanel()
				isOpen = false
				return true
			end
		end
	end

	return false
end

-- Update dragger position on mouse move
local function onInputChanged(input: InputObject)
	if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement and dragFrame then
		local mousePos = UserInputService:GetMouseLocation()
		dragFrame.Position = UDim2.new(0, mousePos.X - SLOT_SIZE / 2, 0, mousePos.Y - SLOT_SIZE / 2)
	end
end

--[[
	===== PUBLIC API =====
]]

function InventoryGUI.Init()
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "InventoryGUI"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")

	-- Panel container (full screen overlay, used for slide animation)
	panel = Instance.new("Frame")
	panel.Name = "Panel"
	panel.Size = UDim2.new(1, 0, 1, 0)
	panel.BackgroundTransparency = 1
	panel.BorderSizePixel = 0
	panel.Visible = false
	panel.ZIndex = 10
	panel.Parent = screenGui

	-- Dragger Frame (standalone, top-level in gui)
	dragFrame = Instance.new("Frame")
	dragFrame.Name = "Dragger"
	dragFrame.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
	dragFrame.BackgroundColor3 = EMPTY_COLOR
	dragFrame.BorderSizePixel = 1
	dragFrame.BorderColor3 = Color3.fromRGB(200, 200, 200)
	dragFrame.ZIndex = 30
	dragFrame.Visible = false
	dragFrame.Parent = screenGui

	-- Build UI content (doesn't set visible yet)
	buildUI()
	panel.Visible = false

	-- Connect remote events
	local conn1 = RemoteEvents.InventoryUpdated.OnClientEvent:Connect(onInventoryUpdated)
	table.insert(remoteConnections, conn1)

	local conn2 = RemoteEvents.GemsUpdated.OnClientEvent:Connect(onGemsUpdated)
	table.insert(remoteConnections, conn2)

	local conn3 = RemoteEvents.WorldLoaded.OnClientEvent:Connect(onWorldLoaded)
	table.insert(remoteConnections, conn3)

	-- Input handling
	local conn4 = UserInputService.InputBegan:Connect(onInputBegan)
	table.insert(inputConnections, conn4)

	local conn5 = UserInputService.InputChanged:Connect(onInputChanged)
	table.insert(inputConnections, conn5)

	print("[InventoryGUI] Initialized")
end

function InventoryGUI.Open()
	if isOpen then return end
	isOpen = true

	-- Rebuild UI (in case inventory changed while closed)
	buildUI()
	openPanel()
end

function InventoryGUI.Close()
	if not isOpen then return end
	isOpen = false
	closePanel()
	cancelDrag()
end

function InventoryGUI.Toggle()
	if isOpen then
		InventoryGUI.Close()
	else
		InventoryGUI.Open()
	end
end

function InventoryGUI.IsOpen(): boolean
	return isOpen
end

function InventoryGUI.Destroy()
	for _, conn in ipairs(remoteConnections) do
		conn:Disconnect()
	end
	for _, conn in ipairs(inputConnections) do
		conn:Disconnect()
	end
	cancelDrag()
	if screenGui then
		screenGui:Destroy()
		screenGui = nil
	end
	slotFrames = {}
	slotData = {}
	print("[InventoryGUI] Destroyed")
end

return InventoryGUI
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="37">
            <Properties>
              <string name="Name">StoreUI</string>
              <string name="Source"><![CDATA[--!strict
-- StoreUI.lua (client)
-- In-game store: press B or click store button to open
-- Shows catalog from GetCatalog RemoteFunction, lets player buy items with gems
-- Shows gem balance at top, quantity selector on buy, success/fail feedback

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = require(ReplicatedStorage.Shared)
local RemoteEvents = require(ReplicatedStorage.Shared.RemoteEvents)
local ItemDatabase = Shared.ItemDatabase

local StoreUI = {}

--[[
	===== CONSTANTS =====
]]

local PANEL_WIDTH = 500
local PANEL_HEIGHT = 400
local TILE_SIZE = 32
local ITEM_ROW_HEIGHT = 48
local BUY_COOLDOWN = 1.0 -- seconds between purchases

--[[
	===== STATE =====
]]

local localPlayer = Players.LocalPlayer
local screenGui: ScreenGui? = nil
local panel: Frame? = nil
local itemList: ScrollingFrame? = nil
local gemBalanceLabel: TextLabel? = nil
local isOpen = false

-- Catalog cache (fetched once on open)
local catalog: { { itemId: number, name: string, price: number, description: string, color: Color3?, isSeed: boolean?, parentBlockName: string? } } = {}

-- Quantity picker state (non-persistent, reset each purchase)
local quantityPicker: Frame? = nil
local quantityValue: number = 1
local quantityLabel: TextLabel? = nil
local pendingItemId: number? = nil
local lastBuyTime = 0

--[[
	===== UI CREATION =====
]]

local function createPanel()
	if not screenGui then return end

	-- Dark overlay (click to close)
	local overlay = Instance.new("Frame")
	overlay.Name = "StoreOverlay"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	overlay.BackgroundTransparency = 0.6
	overlay.BorderSizePixel = 0
	overlay.ZIndex = 50
	overlay.Parent = screenGui

	-- Main panel frame
	panel = Instance.new("Frame")
	panel.Name = "StorePanel"
	panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
	panel.Position = UDim2.new(0.5, -PANEL_WIDTH / 2, 0.5, -PANEL_HEIGHT / 2)
	panel.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
	panel.BackgroundTransparency = 0.1
	panel.BorderSizePixel = 0
	panel.ZIndex = 51
	panel.Parent = screenGui

	-- Title bar
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.Size = UDim2.new(1, 0, 0, 32)
	titleBar.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
	titleBar.BorderSizePixel = 0
	titleBar.ZIndex = 52
	titleBar.Parent = panel

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.Size = UDim2.new(1, -40, 1, 0)
	titleLabel.Position = UDim2.new(0, 10, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = "✦ STORE ✦"
	titleLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
	titleLabel.TextSize = 18
	titleLabel.Font = Enum.Font.SourceSansBold
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextYAlignment = Enum.TextYAlignment.Center
	titleLabel.ZIndex = 53
	titleLabel.Parent = titleBar

	-- Close button
	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseButton"
	closeBtn.Size = UDim2.new(0, 28, 0, 28)
	closeBtn.Position = UDim2.new(1, -32, 0, 2)
	closeBtn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
	closeBtn.BorderSizePixel = 0
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = Color3.fromRGB(255, 200, 200)
	closeBtn.TextSize = 16
	closeBtn.Font = Enum.Font.SourceSansBold
	closeBtn.ZIndex = 53
	closeBtn.Parent = titleBar
	closeBtn.MouseButton1Click:Connect(function()
		StoreUI.Close()
	end)

	-- Gem balance display (top of panel, below title)
	gemBalanceLabel = Instance.new("TextLabel")
	gemBalanceLabel.Name = "GemBalance"
	gemBalanceLabel.Size = UDim2.new(1, -20, 0, 24)
	gemBalanceLabel.Position = UDim2.new(0, 10, 0, 36)
	gemBalanceLabel.BackgroundTransparency = 0.5
	gemBalanceLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	gemBalanceLabel.Text = "◆ Loading..."
	gemBalanceLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
	gemBalanceLabel.TextSize = 16
	gemBalanceLabel.Font = Enum.Font.SourceSansBold
	gemBalanceLabel.TextXAlignment = Enum.TextXAlignment.Center
	gemBalanceLabel.ZIndex = 52
	gemBalanceLabel.Parent = panel

	-- Item list (scrollable)
	itemList = Instance.new("ScrollingFrame")
	itemList.Name = "ItemList"
	itemList.Size = UDim2.new(1, -10, 1, -70)
	itemList.Position = UDim2.new(0, 5, 0, 65)
	itemList.BackgroundTransparency = 1
	itemList.BorderSizePixel = 0
	itemList.ScrollBarThickness = 8
	itemList.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 100)
	itemList.ZIndex = 52
	itemList.CanvasSize = UDim2.new(0, 0, 0, 0)
	itemList.Parent = panel

	-- Quantity picker frame (hidden initially)
	quantityPicker = Instance.new("Frame")
	quantityPicker.Name = "QuantityPicker"
	quantityPicker.Size = UDim2.new(0, 200, 0, 60)
	quantityPicker.Position = UDim2.new(0.5, -100, 0.5, -30)
	quantityPicker.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
	quantityPicker.BorderSizePixel = 0
	quantityPicker.ZIndex = 60
	quantityPicker.Visible = false
	quantityPicker.Parent = screenGui

	-- Quantity picker background (modal overlay)
	local qtyOverlay = Instance.new("Frame")
	qtyOverlay.Name = "QtyOverlay"
	qtyOverlay.Size = UDim2.new(0, 200, 0, 60)
	qtyOverlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	qtyOverlay.BackgroundTransparency = 0.5
	qtyOverlay.BorderSizePixel = 0
	qtyOverlay.ZIndex = 61
	qtyOverlay.Parent = quantityPicker

	-- Quantity controls
	local minusBtn = Instance.new("TextButton")
	minusBtn.Name = "Minus"
	minusBtn.Size = UDim2.new(0, 30, 0, 30)
	minusBtn.Position = UDim2.new(0, 10, 0, 15)
	minusBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
	minusBtn.BorderSizePixel = 0
	minusBtn.Text = "-"
	minusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	minusBtn.TextSize = 20
	minusBtn.Font = Enum.Font.SourceSansBold
	minusBtn.ZIndex = 62
	minusBtn.Parent = quantityPicker
	minusBtn.MouseButton1Click:Connect(function()
		if quantityValue > 1 then
			quantityValue -= 1
			if quantityLabel then
				quantityLabel.Text = tostring(quantityValue)
			end
		end
	end)

	quantityLabel = Instance.new("TextLabel")
	quantityLabel.Name = "Quantity"
	quantityLabel.Size = UDim2.new(0, 60, 0, 30)
	quantityLabel.Position = UDim2.new(0, 50, 0, 15)
	quantityLabel.BackgroundTransparency = 0.5
	quantityLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	quantityLabel.Text = "1"
	quantityLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	quantityLabel.TextSize = 20
	quantityLabel.Font = Enum.Font.SourceSansBold
	quantityLabel.TextXAlignment = Enum.TextXAlignment.Center
	quantityLabel.TextYAlignment = Enum.TextYAlignment.Center
	quantityLabel.ZIndex = 62
	quantityLabel.Parent = quantityPicker

	local plusBtn = Instance.new("TextButton")
	plusBtn.Name = "Plus"
	plusBtn.Size = UDim2.new(0, 30, 0, 30)
	plusBtn.Position = UDim2.new(0, 120, 0, 15)
	plusBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
	plusBtn.BorderSizePixel = 0
	plusBtn.Text = "+"
	plusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	plusBtn.TextSize = 20
	plusBtn.Font = Enum.Font.SourceSansBold
	plusBtn.ZIndex = 62
	plusBtn.Parent = quantityPicker
	plusBtn.MouseButton1Click:Connect(function()
		if quantityValue < 99 then
			quantityValue += 1
			if quantityLabel then
				quantityLabel.Text = tostring(quantityValue)
			end
		end
	end)

	local confirmQtyBtn = Instance.new("TextButton")
	confirmQtyBtn.Name = "Confirm"
	confirmQtyBtn.Size = UDim2.new(0, 120, 0, 26)
	confirmQtyBtn.Position = UDim2.new(0, 40, 0, 50)
	confirmQtyBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 30)
	confirmQtyBtn.BorderSizePixel = 0
	confirmQtyBtn.Text = "BUY"
	confirmQtyBtn.TextColor3 = Color3.fromRGB(200, 255, 200)
	confirmQtyBtn.TextSize = 14
	confirmQtyBtn.Font = Enum.Font.SourceSansBold
	confirmQtyBtn.ZIndex = 62
	confirmQtyBtn.Parent = quantityPicker
	confirmQtyBtn.MouseButton1Click:Connect(function()
		if pendingItemId then
			StoreUI.BuyItem(pendingItemId, quantityValue)
			pendingItemId = nil
		end
		if quantityPicker then
			quantityPicker.Visible = false
		end
	end)

	-- Update gem balance when GemsUpdated fires
	RemoteEvents.GemsUpdated.OnClientEvent:Connect(function(gemCount: number)
		if gemBalanceLabel then
			gemBalanceLabel.Text = `◆ {gemCount}`
		end
	end)

	-- Listen for StoreResult
	RemoteEvents.StoreResult.OnClientEvent:Connect(function(success: boolean, message: string)
		if success then
			-- Green flash notification on the panel
			StoreUI._flashFeedback(true, message)
		else
			-- Red shake notification
			StoreUI._flashFeedback(false, message)
		end
	end)

	-- Clicking overlay closes panel
	overlay.MouseButton1Click:Connect(function()
		StoreUI.Close()
	end)
end

--[[
	Create a row in the item list for a catalog entry.
]]

local function createItemRow(entry: { itemId: number, name: string, price: number, description: string, color: Color3?, isSeed: boolean?, parentBlockName: string? })
	if not itemList then return end

	local rowHeight = ITEM_ROW_HEIGHT
	local row = Instance.new("Frame")
	row.Name = "ItemRow_" .. entry.itemId
	row.Size = UDim2.new(1, -10, 0, rowHeight)
	row.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
	row.BackgroundTransparency = 0.3
	row.BorderSizePixel = 0
	row.ZIndex = 53
	row.Parent = itemList

	-- Item color square
	local colorSquare = Instance.new("Frame")
	colorSquare.Name = "ColorSquare"
	colorSquare.Size = UDim2.new(0, TILE_SIZE, 0, TILE_SIZE)
	colorSquare.Position = UDim2.new(0, 6, 0.5, -TILE_SIZE / 2)
	colorSquare.BackgroundColor3 = entry.color or Color3.fromRGB(150, 150, 150)
	colorSquare.BorderSizePixel = 1
	colorSquare.BorderColor3 = Color3.fromRGB(60, 60, 80)
	colorSquare.ZIndex = 54
	colorSquare.Parent = row

	-- Item name + description
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ItemName"
	nameLabel.Size = UDim2.new(0, 250, 0, 18)
	nameLabel.Position = UDim2.new(0, 46, 0, 4)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = entry.name
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.TextSize = 14
	nameLabel.Font = Enum.Font.SourceSansBold
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.ZIndex = 54
	nameLabel.Parent = row

	local descLabel = Instance.new("TextLabel")
	descLabel.Name = "ItemDesc"
	descLabel.Size = UDim2.new(0, 250, 0, 16)
	descLabel.Position = UDim2.new(0, 46, 0, 22)
	descLabel.BackgroundTransparency = 1
	descLabel.Text = entry.description
	descLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
	descLabel.TextSize = 11
	descLabel.Font = Enum.Font.SourceSans
	descLabel.TextXAlignment = Enum.TextXAlignment.Left
	descLabel.ZIndex = 54
	descLabel.Parent = row

	-- Price label
	local priceLabel = Instance.new("TextLabel")
	priceLabel.Name = "Price"
	priceLabel.Size = UDim2.new(0, 80, 0, 18)
	priceLabel.Position = UDim2.new(0, 310, 0, 6)
	priceLabel.BackgroundTransparency = 1
	priceLabel.Text = `◆ {entry.price}`
	priceLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
	priceLabel.TextSize = 14
	priceLabel.Font = Enum.Font.SourceSansBold
	priceLabel.TextXAlignment = Enum.TextXAlignment.Right
	priceLabel.ZIndex = 54
	priceLabel.Parent = row

	-- Buy button
	local buyBtn = Instance.new("TextButton")
	buyBtn.Name = "BuyButton"
	buyBtn.Size = UDim2.new(0, 70, 0, 28)
	buyBtn.Position = UDim2.new(0, 400, 0.5, -14)
	buyBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 40)
	buyBtn.BorderSizePixel = 0
	buyBtn.Text = "BUY"
	buyBtn.TextColor3 = Color3.fromRGB(200, 255, 200)
	buyBtn.TextSize = 14
	buyBtn.Font = Enum.Font.SourceSansBold
	buyBtn.ZIndex = 55
	buyBtn.Parent = row

	-- Buy button click: show quantity picker
	buyBtn.MouseButton1Click:Connect(function()
		pendingItemId = entry.itemId
		quantityValue = 1
		if quantityLabel then
			quantityLabel.Text = "1"
		end
		if quantityPicker then
			quantityPicker.Visible = true
		end
	end)

	-- Feedback labels (hidden initially)
	local feedbackLabel = Instance.new("TextLabel")
	feedbackLabel.Name = "Feedback"
	feedbackLabel.Size = UDim2.new(0, 200, 0, 20)
	feedbackLabel.Position = UDim2.new(0, 280, 0, 28)
	feedbackLabel.BackgroundTransparency = 1
	feedbackLabel.Text = ""
	feedbackLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
	feedbackLabel.TextSize = 12
	feedbackLabel.Font = Enum.Font.SourceSans
	feedbackLabel.TextXAlignment = Enum.TextXAlignment.Right
	feedbackLabel.ZIndex = 55
	feedbackLabel.Parent = row
end

--[[
	Flash feedback on the store panel (success green flash, failure red shake).
]]

function StoreUI._flashFeedback(success: boolean, message: string)
	if not panel then return end

	-- Create a temporary feedback label in the panel center
	local feedback = Instance.new("TextLabel")
	feedback.Name = "FeedbackFlash"
	feedback.Size = UDim2.new(1, -40, 0, 24)
	feedback.Position = UDim2.new(0, 20, 1, -70)
	feedback.BackgroundTransparency = 0.3
	feedback.BackgroundColor3 = success and Color3.fromRGB(0, 60, 0) or Color3.fromRGB(60, 0, 0)
	feedback.BorderSizePixel = 0
	feedback.Text = message
	feedback.TextColor3 = success and Color3.fromRGB(150, 255, 150) or Color3.fromRGB(255, 150, 150)
	feedback.TextSize = 14
	feedback.Font = Enum.Font.SourceSansBold
	feedback.TextXAlignment = Enum.TextXAlignment.Center
	feedback.TextYAlignment = Enum.TextYAlignment.Center
	feedback.ZIndex = 70
	feedback.Parent = panel

	-- Green flash: fade out after 2s
	if success then
		local fadeOut = TweenService:Create(
			feedback,
			TweenInfo.new(0.5, Enum.EasingStyle.Linear),
			{ BackgroundTransparency = 1, TextTransparency = 1 }
		)
		task.delay(1.5, function()
			fadeOut:Play()
			fadeOut.Completed:Once(function()
				feedback:Destroy()
			end)
		end)
	else
		-- Red shake: brief shake animation then fade
		local originalPos = feedback.Position
		local shake1 = TweenService:Create(
			feedback,
			TweenInfo.new(0.05, Enum.EasingStyle.Linear),
			{ Position = UDim2.new(0, 20, 1, -70) + UDim2.new(0, 5, 0, 0) }
		)
		local shake2 = TweenService:Create(
			feedback,
			TweenInfo.new(0.05, Enum.EasingStyle.Linear),
			{ Position = originalPos }
		)
		shake1:Play()
		shake1.Completed:Once(function()
			shake2:Play()
			task.delay(0.5, function()
				local fadeOut = TweenService:Create(
					feedback,
					TweenInfo.new(0.3, Enum.EasingStyle.Linear),
					{ BackgroundTransparency = 1, TextTransparency = 1 }
				)
				fadeOut:Play()
				fadeOut.Completed:Once(function()
					feedback:Destroy()
				end)
			end)
		end)
	end
end

--[[
	===== PUBLIC API =====
]]

--[[
	Open the store panel.
	Fetches catalog from server and builds UI.
]]

function StoreUI.Open()
	if isOpen then
		StoreUI.Close()
		return
	end

	if not screenGui then
		screenGui = Instance.new("ScreenGui")
		screenGui.Name = "StoreGUI"
		screenGui.ResetOnSpawn = false
		screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		screenGui.Parent = localPlayer:WaitForChild("PlayerGui")
	end

	isOpen = true

	-- Create the panel
	createPanel()

	-- Fetch catalog from server
	local success, result = pcall(function()
		return RemoteEvents.GetCatalog:InvokeServer()
	end)

	if success and result and type(result) == "table" then
		catalog = result

		-- Build item rows
		if itemList then
			-- Clear existing content
			for _, child in ipairs(itemList:GetChildren()) do
				if child:IsA("Frame") then
					child:Destroy()
				end
			end

			-- Layout items in rows
			local yOffset = 0
			for _, entry in ipairs(catalog) do
				createItemRow(entry)
				yOffset += ITEM_ROW_HEIGHT
			end

			-- Update canvas size
			itemList.CanvasSize = UDim2.new(0, 0, 0, yOffset + 10)
		end

		-- Update initial gem balance
		local gemSuccess, gemResult = pcall(function()
			return RemoteEvents.GetInventory:InvokeServer()
		end)
		if not gemSuccess then
			if gemBalanceLabel then
				gemBalanceLabel.Text = "◆ (offline)"
			end
		end
	else
		if gemBalanceLabel then
			gemBalanceLabel.Text = "◆ Failed to load store"
		end
	end
end

--[[
	Close the store panel.
]]

function StoreUI.Close()
	isOpen = false
	if screenGui then
		screenGui:Destroy()
		screenGui = nil
	end
	panel = nil
	itemList = nil
	gemBalanceLabel = nil
	quantityPicker = nil
	pendingItemId = nil
end

--[[
	Buy an item from the store.
	@param itemId: number — catalog item ID
	@param quantity: number — how many to buy (1-99)
]]

function StoreUI.BuyItem(itemId: number, quantity: number)
	local now = os.clock()
	if now - lastBuyTime < BUY_COOLDOWN then
		StoreUI._flashFeedback(false, "Please wait before buying again")
		return
	end
	lastBuyTime = now

	RemoteEvents.RequestPurchase:FireServer(itemId, quantity)
	-- Feedback comes from StoreResult remote event
end

--[[
	Initialize StoreUI (registers keybind).
]]

function StoreUI.Init()
	-- Register B key to toggle store
	UserInputService.InputBegan:Connect(function(input: InputObject, isProcessed: boolean)
		if isProcessed then return end
		if input.KeyCode == Enum.KeyCode.B then
			StoreUI.Open()
		end
	end)

	print("[StoreUI] Initialized")
end

--[[
	Clean up.
]]

function StoreUI.Destroy()
	StoreUI.Close()
	print("[StoreUI] Destroyed")
end

return StoreUI
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="38">
            <Properties>
              <string name="Name">WorldList</string>
              <string name="Source"><![CDATA[-- WorldList.luau
-- Client-side world selection screen (toggle with M)

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Shared = require(ReplicatedStorage.Shared)
local Remotes = Shared.Remotes

local WorldList = {}

local screenGui = nil
local isOpen = false

--[[
	Initialize WorldList
]]
function WorldList.Init()
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "WorldListGUI"
	screenGui.ResetOnSpawn = false

	-- Listen for toggle key (M)
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.M then
			WorldList.Toggle()
		end
	end)

	print("[WorldList] Initialized")
end

--[[
	Toggle world list visibility
]]
function WorldList.Toggle()
	isOpen = not isOpen

	if isOpen then
		screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
		WorldList._buildUI()
	else
		screenGui:Destroy()
		screenGui = Instance.new("ScreenGui")
		screenGui.Name = "WorldListGUI"
		screenGui.ResetOnSpawn = false
	end
end

--[[
	Build the world list UI
]]
function WorldList._buildUI()
	for _, child in ipairs(screenGui:GetChildren()) do
		child:Destroy()
	end

	local bg = Instance.new("Frame")
	bg.Name = "Background"
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bg.BackgroundTransparency = 0.6
	bg.Parent = screenGui

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.Size = UDim2.new(0, 300, 0, 400)
	container.Position = UDim2.new(0.5, -150, 0.5, -200)
	container.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	container.BorderSizePixel = 0
	container.Parent = screenGui

	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, 0, 0, 40)
	title.BackgroundTransparency = 1
	title.Text = "WORLDS"
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextSize = 24
	title.Font = Enum.Font.SourceSansBold
	title.Parent = container

	local worldList = Instance.new("UIListLayout")
	worldList.Padding = UDim.new(0, 5)
	worldList.Parent = container

	-- Main world button
	local mainWorld = Instance.new("TextButton")
	mainWorld.Name = "main"
	mainWorld.Size = UDim2.new(1, -20, 0, 40)
	mainWorld.Position = UDim2.new(0, 10, 0, 50)
	mainWorld.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	mainWorld.Text = "🌍 Main World"
	mainWorld.TextColor3 = Color3.fromRGB(255, 255, 255)
	mainWorld.TextSize = 16
	mainWorld.Font = Enum.Font.SourceSans
	mainWorld.Parent = container

	-- Shop world button
	local shopWorld = Instance.new("TextButton")
	shopWorld.Name = "shop"
	shopWorld.Size = UDim2.new(1, -20, 0, 40)
	shopWorld.Position = UDim2.new(0, 10, 0, 100)
	shopWorld.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	shopWorld.Text = "🛒 BUY+ Shop"
	shopWorld.TextColor3 = Color3.fromRGB(198, 165, 50)
	shopWorld.TextSize = 16
	shopWorld.Font = Enum.Font.SourceSans
	shopWorld.Parent = container

	mainWorld.MouseButton1Click:Connect(function()
		Remotes.Events.PlayerJoined:Fire("main")
		WorldList.Toggle()
	end)

	shopWorld.MouseButton1Click:Connect(function()
		print("[WorldList] Shop world selected")
		WorldList.Toggle()
	end)
end

--[[
	Check if world list is open
]]
function WorldList.IsOpen(): boolean
	return isOpen
end

return WorldList
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="39">
            <Properties>
              <string name="Name">WrenchUI</string>
              <string name="Source"><![CDATA[--!strict
-- WrenchUI.lua (client)
-- Popup panel displayed when wrenching a tile (pressing E on a tile).
-- Shows tile information (fg, bg, hp, tree growth), door destination management,
-- and world lock admin management.
--
-- Architecture:
--   - Server fires WrenchData RemoteEvent → WrenchUI receives it and opens the panel
--   - Panel is a ScreenGui Frame positioned near the wrenched tile
--   - Auto-closes when player moves >3 tiles from the wrenched position
--   - Closes on pressing E again or clicking outside
--   - Fires RequestSetDoorDestination / RequestAddAdmin / RequestRemoveAdmin to server

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local Shared = require(ReplicatedStorage.Shared)
local WorldConfig = Shared.WorldConfig
local ItemDatabase = Shared.ItemDatabase
local RemoteEvents = require(ReplicatedStorage.Shared.RemoteEvents)

local WrenchUI = {}

--[[
	===== CONSTANTS =====
]]

local PANEL_WIDTH = 300
local PANEL_HEIGHT = 320
local PADDING = 8
local ROW_HEIGHT = 24
local FONT = Enum.Font.SourceSans
local FONT_SIZE = 16
local CLOSE_DISTANCE = 3  -- tiles, auto-close if player moves this far from wrenched tile

-- Colors
local BG_COLOR = Color3.fromRGB(30, 30, 35)
local BORDER_COLOR = Color3.fromRGB(60, 60, 70)
local TEXT_COLOR = Color3.fromRGB(220, 220, 220)
local HIGHLIGHT_COLOR = Color3.fromRGB(50, 50, 60)
local ACCENT_COLOR = Color3.fromRGB(100, 180, 255)
local SUCCESS_COLOR = Color3.fromRGB(100, 200, 100)
local ERROR_COLOR = Color3.fromRGB(255, 100, 100)
local BUTTON_COLOR = Color3.fromRGB(50, 50, 60)
local BUTTON_HOVER = Color3.fromRGB(70, 70, 80)
local INPUT_BG = Color3.fromRGB(20, 20, 25)

--[[
	===== STATE =====
]]

local localPlayer = Players.LocalPlayer

local gui: ScreenGui? = nil
local panel: Frame? = nil
local isOpen = false

-- Current wrenched tile data
local wrenchedData = nil  -- table from WrenchData

-- Track position for auto-close
local wrenchedTileX = -1
local wrenchedTileY = -1

-- Player position tracking (updated via RenderStepped)
local playerTileX = 0
local playerTileY = 0

-- Module references
local worldRenderer = nil

--[[
	===== HELPER FUNCTIONS =====
]]

local function createLabel(text: string, textColor: Color3?, fontSize: number?): TextLabel
	local label = Instance.new("TextLabel")
	label.Text = text
	label.TextColor3 = textColor or TEXT_COLOR
	label.TextSize = fontSize or FONT_SIZE
	label.Font = FONT
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(1, -PADDING * 2, 0, ROW_HEIGHT)
	label.Position = UDim2.new(0, PADDING, 0, 0)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	return label
end

local function createButton(text: string, color: Color3?): TextButton
	local btn = Instance.new("TextButton")
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 14
	btn.Font = FONT
	btn.BackgroundColor3 = color or BUTTON_COLOR
	btn.BorderSizePixel = 0
	btn.Size = UDim2.new(0, 80, 0, ROW_HEIGHT)
	btn.AutoButtonColor = false
	return btn
end

local function createTextBox(placeholder: string): TextBox
	local box = Instance.new("TextBox")
	box.Text = ""
	box.PlaceholderText = placeholder
	box.PlaceholderColor3 = Color3.fromRGB(120, 120, 130)
	box.TextColor3 = TEXT_COLOR
	box.TextSize = 14
	box.Font = FONT
	box.BackgroundColor3 = INPUT_BG
	box.BorderSizePixel = 1
	box.BorderColor3 = BORDER_COLOR
	box.Size = UDim2.new(1, -PADDING * 2 - 85, 0, ROW_HEIGHT)
	box.Position = UDim2.new(0, PADDING, 0, 0)
	box.TextXAlignment = Enum.TextXAlignment.Left
	box.ClearTextOnFocus = true
	return box
end

--[[
	Get the item name for a tile fg/bg ID.
	Returns "Empty" or "Unknown" for missing items.
]]
local function getItemDisplayName(itemId: number): string
	if itemId == 0 or itemId == nil then
		return "Empty"
	end
	local item = ItemDatabase.GetItem(itemId)
	if item then
		return item.name or ("Item #" .. itemId)
	end
	return "Item #" .. itemId
end

--[[
	Get the item type name for display.
]]
local function getItemTypeName(itemId: number): string
	if itemId == 0 or itemId == nil then
		return "None"
	end
	local item = ItemDatabase.GetItem(itemId)
	if item and item.type ~= nil then
		local name = WorldConfig.GetItemTypeName(item.type)
		if name then
			return name
		end
		return "Type " .. tostring(item.type)
	end
	return "Unknown"
end

--[[
	===== UI CONSTRUCTION =====
]]

local function buildPanel()
	if not gui then
		gui = Instance.new("ScreenGui")
		gui.Name = "WrenchUIGUI"
		gui.ResetOnSpawn = false
		gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		gui.Parent = localPlayer:WaitForChild("PlayerGui")
	end

	-- Close on overlay click (click outside panel)
	local overlay = Instance.new("Frame")
	overlay.Name = "WrenchOverlay"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.Position = UDim2.new(0, 0, 0, 0)
	overlay.BackgroundTransparency = 0.7
	overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	overlay.BorderSizePixel = 0
	overlay.Active = true
	overlay.Selectable = false
	overlay.Parent = gui

	-- Close overlay on click
	overlay.InputBegan:Connect(function(input: InputObject)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			WrenchUI.Close()
		end
	end)

	-- Main panel frame
	panel = Instance.new("Frame")
	panel.Name = "WrenchPanel"
	panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
	panel.BackgroundColor3 = BG_COLOR
	panel.BorderSizePixel = 1
	panel.BorderColor3 = BORDER_COLOR
	panel.Active = true
	panel.Selectable = true
	panel.Parent = gui

	-- Close button (X)
	local closeBtn = Instance.new("ImageButton")
	closeBtn.Name = "CloseButton"
	closeBtn.Size = UDim2.new(0, 20, 0, 20)
	closeBtn.Position = UDim2.new(1, -25, 0, 5)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Image = "rbxasset://textures/ui/close.png"
	closeBtn.ImageColor3 = Color3.fromRGB(180, 180, 180)
	closeBtn.Parent = panel
	closeBtn.MouseButton1Click:Connect(function()
		WrenchUI.Close()
	end)

	-- Container for dynamic content (cleared and rebuilt on each open)
	local contentContainer = Instance.new("ScrollingFrame")
	contentContainer.Name = "ContentContainer"
	contentContainer.Size = UDim2.new(1, 0, 1, -30)
	contentContainer.Position = UDim2.new(0, 0, 0, 30)
	contentContainer.BackgroundTransparency = 1
	contentContainer.BorderSizePixel = 0
	contentContainer.ScrollBarThickness = 6
	contentContainer.ScrollBarImageColor3 = BORDER_COLOR
	contentContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
	contentContainer.ClipsDescendants = true
	contentContainer.Parent = panel
end

--[[
	Populate the panel with current wrench data.
]]
local function populatePanel()
	if not panel then return end

	local container = panel:FindFirstChild("ContentContainer") :: ScrollingFrame?
	if not container then return end

	-- Clear existing content
	for _, child in ipairs(container:GetChildren()) do
		child:Destroy()
	end

	if not wrenchedData then return end

	local data = wrenchedData
	local currentY = 0

	--[[
		SECTION: Tile Info
	]]
	local titleLabel = createLabel("--- Tile Info ---", ACCENT_COLOR, 14)
	titleLabel.Position = UDim2.new(0, PADDING, 0, currentY)
	titleLabel.Parent = container
	currentY = currentY + ROW_HEIGHT

	-- Foreground block
	local fgInfo = `Foreground: {getItemDisplayName(data.fg)}`
	if data.hp and data.hp > 0 then
		local itemDef = data.fg and ItemDatabase.GetItem(data.fg)
		local maxHp = (itemDef and itemDef.hp) or "?"
		fgInfo = fgInfo .. `  |  HP: {data.hp}/{maxHp}`
	end
	local fgLabel = createLabel(fgInfo)
	fgLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
	fgLabel.TextSize = 14
	fgLabel.Parent = container
	currentY = currentY + ROW_HEIGHT

	-- Foreground type
	local typeLabel = createLabel(`Type: {getItemTypeName(data.fg)}`)
	typeLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
	typeLabel.TextSize = 14
	typeLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
	typeLabel.Parent = container
	currentY = currentY + ROW_HEIGHT

	-- Background block
	local bgLabel = createLabel(`Background: {getItemDisplayName(data.bg)}`)
	bgLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
	bgLabel.TextSize = 14
	bgLabel.Parent = container
	currentY = currentY + ROW_HEIGHT

	--[[
		SECTION: Tree Info
	]]
	if data.treeInfo then
		local sepLabel = createLabel("--- Tree Growth ---", ACCENT_COLOR, 14)
		sepLabel.Position = UDim2.new(0, PADDING, 0, currentY)
		sepLabel.Parent = container
		currentY = currentY + ROW_HEIGHT

		local seedItem = ItemDatabase.GetItem(data.treeInfo.seedId)
		local seedName = seedItem and seedItem.name or ("Seed #" .. data.treeInfo.seedId)
		local growthLabel = createLabel(`Seed: {seedName} | {data.treeInfo.growthPercent}% grown`)
		growthLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
		growthLabel.TextSize = 14
		growthLabel.Parent = container
		currentY = currentY + ROW_HEIGHT

		-- Progress bar
		local progressBg = Instance.new("Frame")
		progressBg.Name = "ProgressBg"
		progressBg.Size = UDim2.new(1, -PADDING * 2 - 16, 0, 8)
		progressBg.Position = UDim2.new(0, PADDING + 8, 0, currentY)
		progressBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
		progressBg.BorderSizePixel = 0
		progressBg.Parent = container

		local progressFill = Instance.new("Frame")
		progressFill.Name = "ProgressFill"
		progressFill.Size = UDim2.new(data.treeInfo.growthPercent / 100, 0, 1, 0)
		progressFill.BackgroundColor3 = Color3.fromRGB(100, 220, 100)
		progressFill.BorderSizePixel = 0
		progressFill.Parent = progressBg

		currentY = currentY + 14
	end

	--[[
		SECTION: Door Management
	]]
	if data.isDoor then
		local sepLabel = createLabel("--- Door Settings ---", ACCENT_COLOR, 14)
		sepLabel.Position = UDim2.new(0, PADDING, 0, currentY)
		sepLabel.Parent = container
		currentY = currentY + ROW_HEIGHT

		if data.isMainDoor then
			-- Main Door is always locked to START
			local mainDoorLabel = createLabel("Main Door → Always goes to START", Color3.fromRGB(255, 200, 100), 14)
			mainDoorLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
			mainDoorLabel.Parent = container
			currentY = currentY + ROW_HEIGHT
		else
			-- Current destination
			local destLabel = createLabel(`Destination: {data.doorDestination or "Not set (default: START)"}`, nil, 14)
			destLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
			destLabel.Parent = container
			currentY = currentY + ROW_HEIGHT

			-- Only show edit controls if player is world owner
			if data.lockInfo and data.lockInfo.isOwner then
				-- Text input row
				local inputRow = Instance.new("Frame")
				inputRow.Name = "DoorInputRow"
				inputRow.Size = UDim2.new(1, 0, 0, ROW_HEIGHT)
				inputRow.Position = UDim2.new(0, 0, 0, currentY)
				inputRow.BackgroundTransparency = 1
				inputRow.Parent = container

				local destInput = createTextBox("World name (e.g. MYWORLD)")
				destInput.Parent = inputRow

				local confirmBtn = createButton("Set", SUCCESS_COLOR)
				confirmBtn.Position = UDim2.new(1, -85, 0, 0)
				confirmBtn.Parent = inputRow

				-- Button hover effects
				confirmBtn.MouseEnter:Connect(function()
					confirmBtn.BackgroundColor3 = Color3.fromRGB(120, 220, 120)
				end)
				confirmBtn.MouseLeave:Connect(function()
					confirmBtn.BackgroundColor3 = SUCCESS_COLOR
				end)

				confirmBtn.MouseButton1Click:Connect(function()
					local dest = string.upper(string.gsub(destInput.Text, "[^%w_]", ""))
					if #dest == 0 then
						warn("[WrenchUI] Invalid destination world name")
						return
					end
					if #dest > 20 then
						dest = string.sub(dest, 1, 20)
					end
					RemoteEvents.RequestSetDoorDestination:FireServer(data.tileX, data.tileY, dest)
					WrenchUI.Close()
				end)

				currentY = currentY + ROW_HEIGHT + 4
			end
		end
	end

	--[[
		SECTION: Lock / Admin Management
	]]
	if data.lockInfo and data.lockInfo.isLocked then
		local sepLabel = createLabel("--- World Lock ---", ACCENT_COLOR, 14)
		sepLabel.Position = UDim2.new(0, PADDING, 0, currentY)
		sepLabel.Parent = container
		currentY = currentY + ROW_HEIGHT

		local ownerLabel = createLabel(`Owner: User #{data.lockInfo.ownerUserId}`, nil, 14)
		ownerLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
		ownerLabel.Parent = container
		currentY = currentY + ROW_HEIGHT

		if data.lockInfo.isOwner then
			-- Admin list
			local adminListLabel = createLabel("Admins:", nil, 14)
			adminListLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
			adminListLabel.Parent = container
			currentY = currentY + ROW_HEIGHT

			if data.lockInfo.admins and #data.lockInfo.admins > 0 then
				for _, adminId in ipairs(data.lockInfo.admins) do
					local adminRow = Instance.new("Frame")
					adminRow.Name = "AdminRow"
					adminRow.Size = UDim2.new(1, 0, 0, ROW_HEIGHT)
					adminRow.Position = UDim2.new(0, 0, 0, currentY)
					adminRow.BackgroundTransparency = 1
					adminRow.Parent = container

					local adminLabel = createLabel(`  • User #{adminId}`, nil, 14)
					adminLabel.Size = UDim2.new(1, -90, 0, ROW_HEIGHT)
					adminLabel.Parent = adminRow

					local removeBtn = createButton("Remove", ERROR_COLOR)
					removeBtn.Position = UDim2.new(1, -85, 0, 0)
					removeBtn.Size = UDim2.new(0, 75, 0, ROW_HEIGHT - 2)
					removeBtn.Parent = adminRow

					removeBtn.MouseEnter:Connect(function()
						removeBtn.BackgroundColor3 = Color3.fromRGB(255, 120, 120)
					end)
					removeBtn.MouseLeave:Connect(function()
						removeBtn.BackgroundColor3 = ERROR_COLOR
					end)

					removeBtn.MouseButton1Click:Connect(function()
						RemoteEvents.RequestRemoveAdmin:FireServer(adminId)
						WrenchUI.Close()
					end)

					currentY = currentY + ROW_HEIGHT
				end
			else
				local noAdminsLabel = createLabel("  No admins", Color3.fromRGB(150, 150, 150), 14)
				noAdminsLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
				noAdminsLabel.Parent = container
				currentY = currentY + ROW_HEIGHT
			end

			-- Add admin row
			local addRow = Instance.new("Frame")
			addRow.Name = "AddAdminRow"
			addRow.Size = UDim2.new(1, 0, 0, ROW_HEIGHT)
			addRow.Position = UDim2.new(0, 0, 0, currentY)
			addRow.BackgroundTransparency = 1
			addRow.Parent = container

			local addInput = createTextBox("User ID to add")
			addInput.Parent = addRow

			local addBtn = createButton("Add", ACCENT_COLOR)
			addBtn.Position = UDim2.new(1, -85, 0, 0)
			addBtn.Parent = addRow

			addBtn.MouseEnter:Connect(function()
				addBtn.BackgroundColor3 = Color3.fromRGB(120, 200, 255)
			end)
			addBtn.MouseLeave:Connect(function()
				addBtn.BackgroundColor3 = ACCENT_COLOR
			end)

			addBtn.MouseButton1Click:Connect(function()
				local targetId = tonumber(addInput.Text)
				if targetId and targetId > 0 then
					RemoteEvents.RequestAddAdmin:FireServer(targetId)
					WrenchUI.Close()
				end
			end)

			currentY = currentY + ROW_HEIGHT + 4
		else
			local notOwnerLabel = createLabel("You are not the world owner", Color3.fromRGB(200, 200, 100), 14)
			notOwnerLabel.Position = UDim2.new(0, PADDING + 8, 0, currentY)
			notOwnerLabel.Parent = container
			currentY = currentY + ROW_HEIGHT
		end
	end

	-- Update canvas size
	container.CanvasSize = UDim2.new(0, 0, 0, currentY + 10)

	-- Update panel height to fit content (capped at 500)
	local newHeight = math.min(currentY + 40, 500)
	panel.Size = UDim2.new(0, PANEL_WIDTH, 0, newHeight)
end

--[[
	Position the panel near the wrenched tile on screen.
]]
local function positionPanel()
	if not panel or not worldRenderer then return end

	-- Get screen position of wrenched tile
	local camOffX, camOffY = worldRenderer.GetCameraOffset()
	local TILE_SIZE = WorldConfig.TILE_SIZE or 32

	local screenX = wrenchedTileX * TILE_SIZE - camOffX
	local screenY = wrenchedTileY * TILE_SIZE - camOffY

	-- Position panel to the right of the tile (or left if near edge)
	local viewportSize = panel.Parent and (panel.Parent :: ScreenGui).AbsoluteSize or Vector2.new(1920, 1080)
	local panelX = screenX + TILE_SIZE + 8
	if panelX + PANEL_WIDTH > viewportSize.X then
		panelX = screenX - PANEL_WIDTH - 8
	end
	if panelX < 4 then panelX = 4 end

	local panelY = screenY
	if panelY + panel.AbsoluteSize.Y > viewportSize.Y then
		panelY = viewportSize.Y - panel.AbsoluteSize.Y - 4
	end
	if panelY < 4 then panelY = 4 end

	panel.Position = UDim2.new(0, panelX, 0, panelY)
end

--[[
	===== PUBLIC API =====
]]

--[[
	Open the WrenchUI with data from a wrenched tile.
	@param data: table — WrenchData table from server
]]
function WrenchUI.Open(data: table)
	if not data then return end

	-- Store data
	wrenchedData = data
	wrenchedTileX = data.tileX
	wrenchedTileY = data.tileY

	-- Build GUI if not created yet
	if not gui or not panel then
		buildPanel()
	end

	-- Repopulate panel with current data
	populatePanel()

	-- Position panel near the wrenched tile
	positionPanel()

	-- Show GUI
	gui.Enabled = true
	isOpen = true

	-- Print for debug
	print(`[WrenchUI] Opened — tile ({data.tileX},{data.tileY}) fg={data.fg}`)
end

--[[
	Close the WrenchUI panel.
]]
function WrenchUI.Close()
	if gui then
		gui.Enabled = false
	end
	isOpen = false
	wrenchedData = nil
	wrenchedTileX = -1
	wrenchedTileY = -1
end

--[[
	Check if the wrench UI is currently open.
	@return boolean
]]
function WrenchUI.IsOpen(): boolean
	return isOpen
end

--[[
	Update player position for auto-close tracking.
	Called from RenderStepped.
	@param tileX: number
	@param tileY: number
]]
function WrenchUI.UpdatePlayerPosition(tileX: number, tileY: number)
	if not isOpen then return end
	if wrenchedTileX < 0 or wrenchedTileY < 0 then return end

	local dist = math.max(math.abs(tileX - wrenchedTileX), math.abs(tileY - wrenchedTileY))
	if dist > CLOSE_DISTANCE then
		WrenchUI.Close()
	end
end

--[[
	Initialize WrenchUI.
	Listens for WrenchData from server and E key to close.
]]
function WrenchUI.Init()
	worldRenderer = require(script.Parent.Parent.WorldRenderer)
	-- PlayerController was deleted in architecture correction; use InputController instead
	-- playerController = require(script.Parent.PlayerController)

	-- Create GUI hidden initially
	buildPanel()
	gui.Enabled = false

	-- Listen for WrenchData from server
	RemoteEvents.WrenchData.OnClientEvent:Connect(function(data: table)
		-- Toggle: if already open and same tile, close it
		if isOpen and wrenchedTileX == data.tileX and wrenchedTileY == data.tileY then
			WrenchUI.Close()
			return
		end
		WrenchUI.Open(data)
	end)

	-- Listen for E key to close if wrench UI is open
	UserInputService.InputBegan:Connect(function(inputObject: InputObject, isProcessed: boolean)
		if isProcessed then return end
		if inputObject.UserInputType == Enum.UserInputType.Keyboard
			and inputObject.KeyCode == Enum.KeyCode.E then
			if isOpen then
				WrenchUI.Close()
			end
		end
	end)

	-- Track player position every frame for auto-close
	RunService.RenderStepped:Connect(function()
		if isOpen and worldRenderer then
			local px, py = worldRenderer.GetPlayerTile()
			WrenchUI.UpdatePlayerPosition(px, py)
		end
	end)

	print("[WrenchUI] Initialized")
end

--[[
	Clean up resources.
]]
function WrenchUI.Destroy()
	if gui then
		gui:Destroy()
		gui = nil
	end
	panel = nil
	isOpen = false
	wrenchedData = nil
	print("[WrenchUI] Destroyed")
end

return WrenchUI
]]></string>
